{
  "name": "easy-git",
  "displayName": "GitBlms",
  "description": "%extension.description%",
  "version": "1.0.0",
  "publisher": "gee-coder",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gee-coder/git-blms.git"
  },
  "homepage": "https://github.com/gee-coder/git-blms.git",
  "bugs": {
    "url": "https://github.com/gee-coder/git-blms/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1f2532",
    "theme": "dark"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "git",
    "blame",
    "annotate",
    "history",
    "goland",
    "scm"
  ],
  "markdown": "github",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:easy-git.toggleBlame",
    "onCommand:easy-git.showBlame",
    "onCommand:easy-git.hideBlame",
    "onCommand:easy-git.openCommitDetails"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "easy-git.toggleBlame",
        "title": "%command.toggleBlame.title%",
        "category": "Git"
      },
      {
        "command": "easy-git.showBlame",
        "title": "%command.showBlame.title%",
        "category": "Git"
      },
      {
        "command": "easy-git.hideBlame",
        "title": "%command.hideBlame.title%",
        "category": "Git"
      },
      {
        "command": "easy-git.openCommitDetails",
        "title": "%command.openCommitDetails.title%",
        "category": "Git"
      }
    ],
    "keybindings": [
      {
        "command": "easy-git.toggleBlame",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "easy-git.showBlame",
          "when": "resourceScheme == file && !easyGit.enabled",
          "group": "navigation@git-blame"
        },
        {
          "command": "easy-git.hideBlame",
          "when": "resourceScheme == file && easyGit.enabled",
          "group": "navigation@git-blame"
        },
        {
          "command": "easy-git.openCommitDetails",
          "when": "resourceScheme == file && easyGit.enabled",
          "group": "navigation@git-blame"
        }
      ],
      "editor/lineNumber/context": [
        {
          "command": "easy-git.showBlame",
          "when": "resourceScheme == file && !easyGit.enabled",
          "group": "navigation@git-blame"
        },
        {
          "command": "easy-git.hideBlame",
          "when": "resourceScheme == file && easyGit.enabled",
          "group": "navigation@git-blame"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "easy-git.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%config.enabled.description%"
        },
        "easy-git.colorScheme": {
          "type": "string",
          "default": "blue",
          "enum": [
            "blue",
            "green",
            "purple"
          ],
          "description": "%config.colorScheme.description%"
        },
        "easy-git.dateFormat": {
          "type": "string",
          "default": "absolute",
          "enum": [
            "relative",
            "absolute"
          ],
          "description": "%config.dateFormat.description%"
        },
        "easy-git.maxLineCount": {
          "type": "number",
          "default": 5000,
          "minimum": 1,
          "description": "%config.maxLineCount.description%"
        },
        "easy-git.cacheTimeout": {
          "type": "number",
          "default": 60000,
          "minimum": 0,
          "description": "%config.cacheTimeout.description%"
        },
        "easy-git.maxAnnotationWidth": {
          "type": "number",
          "default": 22,
          "minimum": 8,
          "description": "%config.maxAnnotationWidth.description%"
        },
        "easy-git.uncommittedColor": {
          "type": "string",
          "default": "46,160,67",
          "description": "%config.uncommittedColor.description%"
        },
        "easy-git.currentAuthorColor": {
          "type": "string",
          "default": "",
          "description": "%config.currentAuthorColor.description%"
        },
        "easy-git.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "zh-CN",
            "en"
          ],
          "description": "%config.language.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint \"src/**/*.ts\"",
    "pretest": "npm run compile",
    "test": "node --test \"out/test/**/*.test.js\"",
    "vscode:prepublish": "npm run compile",
    "package:vsix": "powershell -ExecutionPolicy Bypass -File ./scripts/publish-openvsx.ps1 -PackageOnly",
    "publish:openvsx": "powershell -ExecutionPolicy Bypass -File ./scripts/publish-openvsx.ps1",
    "publish:openvsx:namespace": "powershell -ExecutionPolicy Bypass -File ./scripts/publish-openvsx.ps1 -CreateNamespace"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^9.23.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0"
  }
}
